{
  "info": {
    "_postman_id": "baf7ca49-f1e4-4c95-9f4d-8d2a81df53ce",
    "name": "Library System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the versioned library system API."
  },
  "item": [
    {
      "name": "Register Borrower",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/borrowers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "borrowers"]
        }
      }
    },
    {
      "name": "Register Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"isbn\": \"9780132350884\",\n  \"title\": \"Clean Code\",\n  \"author\": \"Robert C. Martin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/books",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "books"]
        }
      }
    },
    {
      "name": "List Books",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/books?page=0&size=20&sort=title,asc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "books"],
          "query": [
            {
              "key": "page",
              "value": "0"
            },
            {
              "key": "size",
              "value": "20"
            },
            {
              "key": "sort",
              "value": "title,asc"
            }
          ]
        }
      }
    },
    {
      "name": "Borrow Book",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/v1/borrowers/1/borrowed-books/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "borrowers", "1", "borrowed-books", "1"]
        }
      }
    },
    {
      "name": "Return Book",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/v1/borrowers/1/borrowed-books/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "borrowers", "1", "borrowed-books", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
